# MIDI Image VAE — Environment Variables
# Copy to .env and fill in your keys:  cp .env.example .env
#
# These are loaded automatically by:
#   - scripts/run_experiment.py (via _load_dotenv)
#   - All SLURM scripts (via .env parser block)
#   - scripts/wandb_sync.sh

# HuggingFace token — required for gated models (SD3, FLUX)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Weights & Biases — for experiment tracking
# Get yours at: https://wandb.ai/authorize
WANDB_API_KEY=your_key_here

# Wandb project name (default: midi-image-vae)
WANDB_PROJECT=midi-image-vae

# Wandb entity (team or username). Leave empty for personal default.
WANDB_ENTITY=
